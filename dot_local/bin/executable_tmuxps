#!/usr/bin/env bash

# tmuxps - List processes running under tmux with session and window names
#
# Usage: ./tmuxps

# Enable strict mode
set -euo pipefail

# Check if tmux is installed
if ! command -v tmux >/dev/null 2>&1; then
    echo "Error: tmux is not installed or not in PATH" >&2
    exit 1
fi

# Check if tmux has any active sessions
if ! tmux list-sessions >/dev/null 2>&1; then
    echo "No active tmux sessions found" >&2
    exit 0
fi

# Print header
printf "%-20s %-20s %-10s %-10s %-10s %-10s %-10s %s\n" "SESSION" "WINDOW" "TTY" "PID" "USER" "%CPU" "MEM" "COMMAND"
echo "-------------------- -------------------- ---------- ---------- ---------- ---------- ---------- ------------------"

# Determine OS to set ps command format
ps_format="pid,tty,user,pcpu,rss,comm"
if [[ "$(uname)" == "Darwin" || "$(uname)" == "FreeBSD" ]]; then
    # macOS and FreeBSD use different ps options
    ps_list_cmd="ps -a -o $ps_format"
    tty_prefix=""
else
    # Linux
    ps_list_cmd="ps ax -o $ps_format"
    tty_prefix="pts/"
fi

# Create a temporary file to store TTY mappings (compatible with older Bash)
tmux_info_file=$(mktemp)
trap 'rm -f "$tmux_info_file"' EXIT

# Get all pane TTYs and their session/window information in one go
tmux list-panes -a -F "#{pane_tty} #{session_name} #{window_name}" | while read -r pane_tty session_name window_name; do
    # Extract just the TTY device name (remove /dev/ prefix)
    tty_short=${pane_tty#/dev/}

    # Store session and window name for each TTY
    echo "$tty_short $session_name $window_name" >>"$tmux_info_file"
done

# Get all processes once
$ps_list_cmd | awk 'NR>1 {print $1, $2, $3, $4, $5, $6}' | while read -r pid tty user pcpu rss comm; do
    # Look up this TTY in our mapping file
    session_window=$(grep "^$tty " "$tmux_info_file" 2>/dev/null || true)

    # Skip processes not in tmux
    if [ -z "$session_window" ]; then
        continue
    fi

    # Parse the session and window names
    session_name=$(echo "$session_window" | cut -d' ' -f2)
    window_name=$(echo "$session_window" | cut -d' ' -f3)

    # Convert RSS to MB with safeguard against division by zero
    if [ "$rss" != "0" ] && [ -n "$rss" ]; then
        mem_mb=$(awk "BEGIN {printf \"%.1f\", $rss/1024}")
    else
        mem_mb="0.0"
    fi

    printf "%-20s %-20s %-10s %-10s %-10s %-10s %-10s %s\n" \
        "$session_name" "$window_name" "$tty" "$pid" "$user" "$pcpu" "${mem_mb}MB" "$comm"
done
